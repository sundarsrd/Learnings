brew "yt-dlp"

# https://formulae.brew.sh/cask/background-music#default
# Background Music is a macOS audio utility that automatically pauses your music, ducking the volume of other apps, when other audio starts playing. It also allows you to set individual volume levels for each of your apps.
cask "background-music"

# https://formulae.brew.sh/cask/bruno#default
# Bruno is a powerful, open-source, and free database client for developers and data analysts. It provides an intuitive interface for managing and querying databases, making it easier to work with various database systems.
cask "bruno"

# https://formulae.brew.sh/cask/dbeaver-community#default
# DBeaver Community Edition is a free, open-source, universal database tool for developers and
cask "dbeaver-community"

# https://formulae.brew.sh/cask/devtoys#default
