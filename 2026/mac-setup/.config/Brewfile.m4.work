# --Pre-reqs - Tools, Libs ---------------------------------------------------------------------------------------------
# https://formulae.brew.sh/formula/gh#default
# GitHub command-line tool
brew "gh"
brew "git"

# https://formulae.brew.sh/formula/eget#default
# Easily install prebuilt binaries from GitHub
brew "eget"

# https://formulae.brew.sh/cask/git-credential-manager#default
# Git Credential Manager (GCM) is a secure Git credential helper built on .NET that
# cask "git-credential-manager"

# https://formulae.brew.sh/cask/github#default
# Desktop client for GitHub repositories
cask "github"

# https://github.com/romankurnovskii/homebrew-awesome-brew
# https://github.com/romankurnovskii/BrewMate
# A curated list of awesome Homebrew packages and casks. Contribute to romankurnovskii/awesome-brew development by creating an account on GitHub.
# BrewMate is a command-line tool that helps you manage your Homebrew packages and casks. It provides an easy way to keep track of your installed packages, update them, and clean up old versions. 
tap "romankurnovskii/awesome-brew"
cask "brewmate"

# https://github.com/Homebrew/homebrew-services/tree/master?tab=readme-ov-file
# Homebrew services is a convenient method of starting Homebrew-installed services using the macOS launchctl manager. It allows you to easily manage background services that are installed via Homebrew, such as databases, web servers, and other daemons.
# tap "homebrew/services"

# https://formulae.brew.sh/formula/telnet#default
# Telnet client and server
brew "telnet"

# --Terminal & Shell-------------------------------------------------------------------

# https://formulae.brew.sh/cask/iterm2#default
# Terminal emulator as alternative to Apple's Terminal app
cask "iterm2"

# https://formulae.brew.sh/formula/zsh#default
# Z shell
brew "zsh"
